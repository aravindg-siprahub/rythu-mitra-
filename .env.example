# ─────────────────────────────────────────────────────────────────
#  Rythu Mitra — Required Environment Variables
#  Copy this file to backend/.env and fill in your real values
# ─────────────────────────────────────────────────────────────────

# ── Django Core ───────────────────────────────────────────────────
SECRET_KEY=django-insecure-replace-this-with-a-long-random-string
DEBUG=True
ALLOWED_HOSTS=*

# ── Redis (local dev default — change for hosted Redis) ───────────
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# ── Supabase ──────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key
SUPABASE_JWT_SECRET=your-supabase-jwt-secret

# ── AI APIs ───────────────────────────────────────────────────────
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
GROQ_API_KEY=your-groq-api-key

# ── Weather ───────────────────────────────────────────────────────
OPENWEATHER_API_KEY=your-openweathermap-api-key

# ── CORS (add your Vercel frontend URL for production) ────────────
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,https://your-app.vercel.app
